# Telegram API credentials
# Obtain from https://my.telegram.org/apps
API_ID=123456
API_HASH=your_api_hash_here

# Session name (file will be saved as <SESSION_NAME>.session)
SESSION_NAME=mirror_bot

# Source channel numeric ID (e.g. -1001234567890)
SOURCE_CHANNEL=-1001234567890

# Destination channel numeric ID (e.g. -1009876543210)
DESTINATION_CHANNEL=-1009876543210

# --- Optional settings ---

# Delete mirrored messages when source message is deleted (true/false)
ENABLE_DELETE_SYNC=false

# Max concurrent media downloads
MAX_CONCURRENT_DOWNLOADS=3

# Delay (seconds) between sending messages during historical sync
HISTORICAL_SEND_DELAY=0.5

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=telegram_channel_mirror
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Temporary media directory (relative path)
TEMP_MEDIA_DIR=temp_media

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
